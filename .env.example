# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# X (Twitter) API v2 - OAuth 1.0a
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# 検索設定
SEARCH_KEYWORDS=プログラミング,AI,テクノロジー   # カンマ区切りで複数指定
SEARCH_DAYS=7                                    # 何日前までの動画を対象にするか
MAX_RESULTS_PER_KEYWORD=20                       # キーワードごとに取得する最大動画数
TOP_N=3                                          # ポストする動画数（上位N件）
POST_INTERVAL_SECONDS=60                         # 複数ポスト時の間隔（秒）
DRY_RUN=false                                    # true にするとポストせずログだけ出力
